APP_NAME=AI Crop Yield Prediction API
APP_ENV=development
API_PORT=8000
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=crop_yield_ai

# Google OAuth (required for login)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
ALLOW_DEV_AUTH=true

# Optional OpenAI chatbot integration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ML artifacts
MODEL_ARTIFACT_PATH=backend/models/crop_yield_model.joblib
