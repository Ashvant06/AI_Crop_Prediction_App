APP_NAME=AI Crop Yield Prediction API
APP_ENV=development
API_PORT=8000
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=crop_yield_ai
LOCAL_DB_FALLBACK=true
LOCAL_DB_PATH=backend/data/local_store.json

# Phone login
# No OAuth provider setup is required for phone-number login in this project.
ALLOW_DEV_AUTH=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=^https://.*\.onrender\.com$

# Optional OpenAI chatbot integration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
KNOWLEDGE_BASE_PATHS=backend/data/knowledge/general_agri_knowledge.json
KNOWLEDGE_TOP_K=6

# ML artifacts
MODEL_ARTIFACT_PATH=backend/models/crop_yield_model.joblib
